# =========================================================================
# AlKabeer frontend — environment template.
# Copy this file to frontend/.env and fill in REAL values. Never commit .env.
#
# Vite inlines VITE_* variables at BUILD time. After changing any VITE_*
# value you must rebuild (locally: restart `npm run dev`; on Vercel:
# trigger a redeploy from the dashboard).
# =========================================================================

# Backend base URL (the deployed Fly.io URL in production).
# Local development:
VITE_API_URL=http://localhost:5000

# Production (set this in Vercel → Project → Settings → Environment Variables):
# VITE_API_URL=https://alkabeer-prod.fly.dev
