# =========================================================================
# AlKabeer backend — environment template.
# Copy this file to backend/.env and fill in REAL values. Never commit .env.
# =========================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=5000

# --- Auth ------------------------------------------------------------------
# Generate a strong secret (≥32 chars):  openssl rand -hex 64
JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
GUEST_JWT_EXPIRES_IN=24h

# --- Frontend origin (for CORS) -------------------------------------------
# In production set this to the deployed Vercel URL, e.g. https://alkabeer.vercel.app
FRONTEND_URL=http://localhost:5173
# Optional comma-separated extra origins (e.g. preview deployments):
# EXTRA_CORS_ORIGINS=https://alkabeer-git-feature-x.vercel.app,https://example.com

# --- Database (Neon Postgres) ---------------------------------------------
# Get this from: Neon dashboard → your project → Connection string → "Pooled connection".
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- AI (Google Gemini) — PRIMARY -----------------------------------------
# Create at https://aistudio.google.com/apikey  — never paste the real key into git.
GEMINI_API_KEY=your_gemini_api_key_here
# Models (override only if defaults are unavailable in your region/tier):
GEMINI_ARCHIVE_MODEL=gemini-2.5-pro
# Internal Gemini fallback used when the primary archive model returns 429 /
# rate-limit / temporary unavailability. Stays inside the "gemini" source.
# Set to the same value as GEMINI_ARCHIVE_MODEL to disable this rung.
GEMINI_ARCHIVE_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_NARRATION_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
# Output-token ceilings. Gemini 2.5 are THINKING models — this budget covers
# both the hidden reasoning tokens AND the visible response. Archive needs
# headroom (~8K) to finish JSON without finishReason=MAX_TOKENS.
GEMINI_ARCHIVE_MAX_OUTPUT_TOKENS=8192
GEMINI_NARRATION_MAX_OUTPUT_TOKENS=1024

# --- AI (OpenRouter) — OPTIONAL SECONDARY FALLBACK ------------------------
# Used ONLY when Gemini fails or its output fails validation.
# If OPENROUTER_API_KEY is empty or AI_FALLBACK_PROVIDER is not "openrouter",
# the chain skips OpenRouter and falls back to the built-in scenario.
# Get a key at https://openrouter.ai/keys — never commit the real key.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_TIMEOUT_MS=30000
# Output-token ceilings for OpenRouter. Arabic JSON is token-dense (~3 tokens
# per Arabic letter), so archive needs ~6K to fit a complete sealed archive.
OPENROUTER_ARCHIVE_MAX_TOKENS=6000
OPENROUTER_NARRATION_MAX_TOKENS=800
# Set to "openrouter" to enable the fallback. Any other value disables it.
AI_FALLBACK_PROVIDER=

# --- Rate limits (sensible defaults) --------------------------------------
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=20
AI_RATE_WINDOW_MS=60000
AI_RATE_MAX=6
